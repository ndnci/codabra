{
    "name": "@codabra/core",
    "version": "0.1.0",
    "private": true,
    "description": "Core config loading, parsing, validation, and compilation logic for Codabra",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "src/schemas"
    ],
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts --clean",
        "dev": "tsup src/index.ts --format esm --dts --watch",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.4.0",
        "@types/node": "^20.12.0"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./schemas/*": "./src/schemas/*"
    }
}
