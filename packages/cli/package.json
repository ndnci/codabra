{
    "name": "@ndnci/codabra",
    "version": "0.1.1-alpha.1",
    "description": "Codabra CLI — generate and orchestrate applications from config files",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "codabra": "./bin/codabra.js",
        "create-codabra": "./bin/create-codabra.js"
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@codabra/core": "workspace:*",
        "@codabra/providers": "workspace:*",
        "commander": "^12.0.0",
        "@inquirer/prompts": "^5.0.0",
        "chalk": "^4.1.2",
        "ora": "^5.4.1"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.4.0",
        "@types/node": "^20.12.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
