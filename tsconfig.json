{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "Preserve",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true
    },
    "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
