[
    {
        "method": "GET",
        "path": "/api/users",
        "response": "User[]"
    },
    {
        "method": "POST",
        "path": "/api/users",
        "body": {
            "email": {
                "type": "string",
                "required": true,
                "validation": ["notEmpty", "isEmail"]
            },
            "name": {
                "type": "string",
                "required": true,
                "validation": ["notEmpty"]
            }
        },
        "response": "User"
    },
    {
        "method": "GET",
        "path": "/api/users/:id",
        "params": { "id": "uuid" },
        "response": "User"
    },
    {
        "method": "PUT",
        "path": "/api/users/:id",
        "params": { "id": "uuid" },
        "body": {
            "name": { "type": "string", "required": false }
        },
        "response": "User"
    },
    {
        "method": "DELETE",
        "path": "/api/users/:id",
        "params": { "id": "uuid" }
    }
]
